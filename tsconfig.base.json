{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "${configDir}/dist",
    "baseUrl": "${configDir}",
    "paths": {
      "@repo/core": ["./packages/core/src"],
      "@repo/core/*": ["./packages/core/src/*"],
      "@repo/db-dexie": ["./packages/db-adapter-dexie/src"],
      "@repo/ui-core": ["./packages/ui-core/src"],
      "@repo/ui-core/*": ["./packages/ui-core/src/*"],
      "@repo/entity-customer": ["./packages/entity-customer/src"],
      "@repo/entity-customer/*": ["./packages/entity-customer/src/*"],
      "@repo/entity-member": ["./packages/entity-member/src"],
      "@repo/entity-member/*": ["./packages/entity-member/src/*"],
      "@repo/entity-share-capital": ["./packages/entity-share-capital/src"],
      "@repo/entity-share-capital/*": ["./packages/entity-share-capital/src/*"],
      "@repo/entity-savings": ["./packages/entity-savings/src"],
      "@repo/entity-savings/*": ["./packages/entity-savings/src/*"],
      "@repo/entity-loan": ["./packages/entity-loan/src"],
      "@repo/entity-loan/*": ["./packages/entity-loan/src/*"],
      "@repo/entity-accounting": ["./packages/entity-accounting/src"],
      "@repo/entity-accounting/*": ["./packages/entity-accounting/src/*"],
      "@repo/entity-collection": ["./packages/entity-collection/src"],
      "@repo/entity-collection/*": ["./packages/entity-collection/src/*"],
      "@repo/entity-governance": ["./packages/entity-governance/src"],
      "@repo/entity-governance/*": ["./packages/entity-governance/src/*"]
    }
  },
  "exclude": ["node_modules", "dist", "build", ".turbo"]
}
